; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Type To Squad"
config/description="An app that uses Window's speech synthesis and fowards it into select audio devices"
config/version="0.5.1"
run/main_scene="uid://c4k01cdp7xpsd"
run/enable_alt_space_menu=true
config/use_custom_user_dir=true
config/custom_user_dir_name="Kodipher/TypeToSquad"
config/auto_accept_quit=false
config/features=PackedStringArray("4.5", "C#", "GL Compatibility")
run/flush_stdout_on_print=true
run/max_fps=60
run/low_processor_mode=true
boot_splash/bg_color=Color(0.105, 0.12, 0.15, 1)
boot_splash/show_image=false
boot_splash/fullsize=false
boot_splash/use_filter=false
config/icon="uid://g03we4p304wj"

[audio]

driver/output_latency=30

[autoload]

UserSettingsManager="*res://Model/UserSettingsManager.cs"
AudioManager="*res://Model/AudioManager.cs"
SpeechDaemon="*res://Model/SpeechDaemon.cs"
HistoryTracker="*res://Model/HistoryTracker.cs"
LogMonitor="*res://Model/LogMonitor.cs"
ExitHandler="*res://Model/ExitHandler.cs"
WindowManager="*res://Gui/WindowManager.cs"

[copy_files_on_export]

files=Array[PackedStringArray]([PackedStringArray("res://WinRTSpeechDaemon", "WinRTSpeechDaemon", "windows")])

[display]

window/size/viewport_width=500
window/size/viewport_height=150
window/energy_saving/keep_screen_on=false
window/subwindows/embed_subwindows=false

[dotnet]

project/assembly_name="Type To Squad"

[editor_plugins]

enabled=PackedStringArray("res://addons/copy_files_on_export/plugin.cfg")

[gui]

timers/button_shortcut_feedback_highlight_time=0.1

