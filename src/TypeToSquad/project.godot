; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Type To Squad"
config/description="An app that uses Window's speech synthesis and fowards it into select audio devices"
config/version="v0.0.0-alpha.0.dev"
run/main_scene="uid://cdeue8fjdyebt"
run/enable_alt_space_menu=true
config/use_custom_user_dir=true
config/custom_user_dir_name="Kodipher/TypeToSquad"
config/auto_accept_quit=false
config/features=PackedStringArray("4.4", "C#", "GL Compatibility")
run/max_fps=60
run/low_processor_mode=true
boot_splash/show_image=false
boot_splash/fullsize=false

[copy_files_on_export]

files=Array[PackedStringArray]([PackedStringArray("res://WinRTSpeechDaemon", "WinRTSpeechDaemon", "windows")])

[display]

window/size/viewport_width=500
window/size/viewport_height=150
window/energy_saving/keep_screen_on=false
window/subwindows/embed_subwindows=false

[dotnet]

project/assembly_name="Type To Squad"

[editor_plugins]

enabled=PackedStringArray("res://addons/copy_files_on_export/plugin.cfg")

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
